#!/usr/bin/env -S uv run python
"""Prepare leakage-safe SARSteer alpha-dev and held-out Run 9 gate manifests.

The old 300-row directional core is development data only.  This script never
reads historical model outputs or judge labels: the positive-control cohorts
are selected from a frozen ID contract and PAP render inventory alone.
"""

from __future__ import annotations

import argparse
import hashlib
import json
import math
from collections import Counter, defaultdict
from collections.abc import Mapping, Sequence
from dataclasses import dataclass
from pathlib import Path
from typing import Any

from audio_safety.data.run9_eval_manifest import atomic_save_jsonl
from audio_safety.utils.io import load_jsonl, save_json

HARMFUL_CATEGORIES = tuple(range(1, 8))
SOFT_CATEGORIES = tuple(range(8, 11))
FINAL_HARMFUL_PER_CATEGORY = 10
FINAL_SOFT_PER_CATEGORY = 10
FINAL_UTILITY_ROWS = 30
FINAL_POSITIVE_CONTROL_ROWS = 30
FINAL_ROWS = 300

DEV_SOFT_PER_CATEGORY = 5
DEV_UTILITY_ROWS = 15
DEV_POSITIVE_CONTROL_ROWS = 30
DEV_ROWS = 76

# Frozen before the adapted final evaluation.  These IDs were chosen solely by
# PAP asset availability, not by any model outcome or historical judge label.
