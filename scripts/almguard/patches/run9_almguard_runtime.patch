+def _latest_resume_checkpoint(save_path, num_epochs, n_audios):
+    """Return (linear_step, path) of the furthest completed (epoch, audio) step.
+
+    Universal training is one flat sequence of (epoch, audio) steps saved as
+    ``perturb_mel_epoch_{E}_iter_{I}.pth``.  Because the Adam optimizer is created
+    fresh inside ``qwen_mel_protection`` per audio (no cross-audio optimizer state)
+    and each forward pass is deterministic/greedy, reloading the furthest checkpoint
+    and continuing at the next step reproduces the uninterrupted trajectory EXACTLY
+    under a pure step cap (``max_seconds=None``).  With the wall-clock watchdog the
+    per-audio step count is timing-dependent, so a resumed δ is not bit-reproducible
+    when the watchdog fires — but each audio still saves exactly one checkpoint and
+    the SAP remains a validly-trained artifact.  Returns ``None`` when no usable
+    checkpoint exists.
+    """
+    best = None
+    pattern = re.compile(r"^perturb_mel_epoch_(\d+)_iter_(\d+)\.pth$")
+    for path in glob.glob(os.path.join(save_path, "perturb_mel_epoch_*_iter_*.pth")):
+        match = pattern.match(os.path.basename(path))
+        if not match:
+            continue
+        epoch, audio_index = int(match.group(1)), int(match.group(2))
+        if epoch >= num_epochs or audio_index >= n_audios:
+            continue
+        step = epoch * n_audios + audio_index
+        if best is None or step > best[0]:
+            best = (step, path)
+    return best
+
+
